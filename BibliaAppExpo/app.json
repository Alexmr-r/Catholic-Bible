{
  "expo": {
    "name": "BibliaAppExpo",
    "slug": "BibliaAppExpo",
    "scheme": "bibliaappexpo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-padded.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF9F6",
      "dark": {
        "image": "./assets/splash-padded-dark.png",
        "backgroundColor": "#121212"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alexmr.biblia",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.alexmr.biblia",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAF9F6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          },
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "La aplicación necesita acceso a tus fotos para que puedas elegir tu foto de perfil.",
          "cameraPermission": "La aplicación necesita acceso a tu cámara para que puedas tomar una foto de perfil."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}