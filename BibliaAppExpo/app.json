{
  "expo": {
    "name": "CatholicVerse",
    "slug": "CatholicVerse",
    "scheme": "catholicverse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-padded.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF9F6",
      "dark": {
        "image": "./assets/splash-padded.png",
        "backgroundColor": "#FAF9F6"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.catholicverse.app",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "CatholicVerse requires speech recognition so you can speak your search queries.",
        "NSMicrophoneUsageDescription": "CatholicVerse needs access to the microphone to hear your voice searches.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1055569033141-8ol7lvhvgn445bfgcha7l74e7kjsshcr"
            ]
          }
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF9F6"
      },
      "splash": {
        "image": "./assets/splash-padded.png",
        "resizeMode": "contain",
        "backgroundColor": "#FAF9F6",
        "dark": {
          "image": "./assets/splash-padded.png",
          "backgroundColor": "#FAF9F6"
        }
      },
      "package": "com.catholicverse.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.0"
          },
          "android": {
            "minSdkVersion": 24,
            "enableAndroidX": true,
            "enableJetifier": true,
            "packagingOptions": {
              "pickFirst": [
                "META-INF/*.version",
                "META-INF/androidx.*.version"
              ]
            }
          }
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "CatholicVerse needs access to your photos so you can choose a profile picture.",
          "cameraPermission": "CatholicVerse needs access to your camera so you can take a profile picture."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "CatholicVerse needs access to the microphone to hear your voice searches.",
          "speechRecognitionPermission": "CatholicVerse requires speech recognition so you can speak your search queries."
        }
      ],
      "./plugins/withAndroidReplaceAppComponentFactory",
      "./plugins/withAndroidExcludeSupport"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7e3bca76-9b41-433f-bea5-6dd153ae0b28"
      }
    }
  }
}
